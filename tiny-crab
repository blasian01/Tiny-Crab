#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  if [[ "$LINK_TARGET" = /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/$LINK_TARGET"
  fi
done
REPO_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

for bin_dir in /opt/homebrew/bin /usr/local/bin; do
  case ":$PATH:" in
    *":$bin_dir:"*) ;;
    *) PATH="$bin_dir:$PATH" ;;
  esac
done
export PATH

export CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.tiny-crab}"

normalize_url() {
  local raw="$1"
  if [[ "$raw" == http://* || "$raw" == https://* ]]; then
    printf '%s' "$raw"
  else
    printf 'http://%s' "$raw"
  fi
}

cleanup_tui() {
  tput cnorm >/dev/stderr 2>/dev/null || true
}

set_env_if_needed() {
  local name="$1"
  local value="$2"
  local force="${3:-0}"
  if [[ "$force" == "1" || -z "${!name:-}" ]]; then
    export "$name=$value"
  fi
}

json_node() {
  local script="$1"
  shift || true
  node -e "$script" "$@"
}

build_local_auth_headers() {
  local token="${LOCAL_PROVIDER_AUTH_TOKEN:-}"
  if [[ -n "$token" ]]; then
    printf '%s\n' "-H" "Authorization: Bearer $token"
  fi
}

curl_json() {
  local method="$1"
  local url="$2"
  local body="${3:-}"
  local -a args=(curl -sS --max-time 30 "$url")
  local header

  while IFS= read -r header; do
    args+=("$header")
  done < <(build_local_auth_headers)

  if [[ "$method" == "POST" ]]; then
    args+=(-H 'Content-Type: application/json' -X POST -d "$body")
  fi

  "${args[@]}"
}

has_ollama() {
  command -v ollama >/dev/null 2>&1
}

has_ollama_server() {
  curl -fsS --max-time 5 "${OLLAMA_BASE_URL%/}/api/tags" >/dev/null 2>&1
}

has_lmstudio_server() {
  curl_json GET "${LMSTUDIO_BASE_URL%/}/api/v1/models" >/dev/null 2>&1
}

get_ollama_models() {
  if has_ollama; then
    ollama list 2>/dev/null | awk 'NR > 1 && NF > 0 { print $1 }' | awk '!/:cloud$/'
    return 0
  fi

  curl -fsS --max-time 10 "${OLLAMA_BASE_URL%/}/api/tags" \
    | json_node 'const fs=require("fs"); const raw=fs.readFileSync(0,"utf8"); const payload=raw ? JSON.parse(raw) : {}; for (const model of payload.models || []) { const name=typeof model?.name === "string" ? model.name : (typeof model?.model === "string" ? model.model : ""); if (name && !name.endsWith(":cloud")) console.log(name); }'
}

get_lmstudio_models() {
  curl_json GET "${LMSTUDIO_BASE_URL%/}/api/v1/models" \
    | json_node 'const fs=require("fs"); const raw=fs.readFileSync(0,"utf8"); const payload=raw ? JSON.parse(raw) : {}; for (const model of payload.models || []) { if (model?.type !== "llm") continue; const key=typeof model?.key === "string" ? model.key : ""; if (!key) continue; const display=typeof model?.display_name === "string" && model.display_name ? model.display_name : key; const maxCtx=Number.isFinite(model?.max_context_length) ? model.max_context_length : ""; const loaded=Array.isArray(model?.loaded_instances) && model.loaded_instances[0] && typeof model.loaded_instances[0].id === "string" ? model.loaded_instances[0].id : ""; console.log([key, display, maxCtx, loaded].join("\t")); }'
}

get_ollama_model_context_length() {
  local model="$1"
  local context_length

  if has_ollama; then
    context_length="$(
      ollama show "$model" 2>/dev/null \
        | awk 'tolower($0) ~ /context length/ { print $0; exit }' \
        | tr -cd '0-9'
    )"
  else
    context_length="$(
      curl -fsS --max-time 10 "${OLLAMA_BASE_URL%/}/api/show" \
        -H 'Content-Type: application/json' \
        -X POST \
        -d "$(printf '{"model":"%s"}' "$model")" 2>/dev/null \
        | json_node 'const fs=require("fs"); const raw=fs.readFileSync(0,"utf8"); const payload=raw ? JSON.parse(raw) : {}; const candidates=[payload?.details?.context_length,payload?.model_info?.context_length,payload?.parameters?.num_ctx,payload?.parameters?.context_length]; for (const value of candidates) { const n=Number(value); if (Number.isFinite(n) && n > 0) { console.log(n); process.exit(0); } } process.exit(1);' \
        || true
    )"
  fi

  if [[ -z "$context_length" || ! "$context_length" =~ ^[0-9]+$ || "$context_length" -le 0 ]]; then
    return 1
  fi
  printf '%s' "$context_length"
}

get_lmstudio_model_context_length() {
  local model="$1"
  local instance_id="${2:-}"

  curl_json GET "${LMSTUDIO_BASE_URL%/}/api/v1/models" \
    | json_node 'const fs=require("fs"); const targetModel=process.argv[1] || ""; const targetInstance=process.argv[2] || ""; const raw=fs.readFileSync(0,"utf8"); const payload=raw ? JSON.parse(raw) : {}; for (const model of payload.models || []) { if (model?.type !== "llm") continue; const key=typeof model?.key === "string" ? model.key : ""; const loaded=Array.isArray(model?.loaded_instances) ? model.loaded_instances : []; const matchingInstance=loaded.find(item => typeof item?.id === "string" && item.id === targetInstance) || loaded.find(item => typeof item?.id === "string" && item.id === targetModel); if (targetInstance && matchingInstance?.config?.context_length) { console.log(matchingInstance.config.context_length); process.exit(0); } if (key === targetModel) { if (matchingInstance?.config?.context_length) { console.log(matchingInstance.config.context_length); process.exit(0); } const fallback=Number(model?.max_context_length); if (Number.isFinite(fallback) && fallback > 0) { console.log(fallback); process.exit(0); } } } process.exit(1);' "$model" "$instance_id"
}

resolve_lmstudio_instance_id() {
  local model="$1"

  curl_json GET "${LMSTUDIO_BASE_URL%/}/api/v1/models" \
    | json_node 'const fs=require("fs"); const target=process.argv[1] || ""; const raw=fs.readFileSync(0,"utf8"); const payload=raw ? JSON.parse(raw) : {}; for (const model of payload.models || []) { const loaded=Array.isArray(model?.loaded_instances) ? model.loaded_instances : []; for (const item of loaded) { if (typeof item?.id === "string" && item.id === target) { console.log(item.id); process.exit(0); } } if (typeof model?.key === "string" && model.key === target) { const first=loaded.find(item => typeof item?.id === "string"); console.log(first?.id || model.key); process.exit(0); } } process.exit(1);' "$model"
}

derive_max_output_tokens_for_context() {
  local context_length="$1"
  local max_output_tokens=$(( context_length / 16 ))
  local max_output_cap="${CLAUDE_DEV_MAX_OUTPUT_TOKENS_CAP:-2048}"

  if [[ ! "$max_output_cap" =~ ^[0-9]+$ ]] || (( max_output_cap <= 0 )); then
    max_output_cap=2048
  fi

  if (( max_output_tokens < 512 )); then
    max_output_tokens=512
  fi
  if (( max_output_tokens > max_output_cap )); then
    max_output_tokens=$max_output_cap
  fi
  if (( max_output_tokens >= context_length )); then
    max_output_tokens=$(( context_length - 1 ))
  fi
  if (( max_output_tokens < 256 )); then
    max_output_tokens=256
  fi

  printf '%s' "$max_output_tokens"
}

apply_context_limits() {
  local context_length="$1"
  local context_cap
  local max_output_tokens

  context_cap="${CLAUDE_DEV_CONTEXT_WINDOW_CAP:-32768}"
  if [[ "$context_cap" =~ ^[0-9]+$ ]] && (( context_cap > 0 )) && (( context_length > context_cap )); then
    context_length="$context_cap"
  fi

  max_output_tokens="$(derive_max_output_tokens_for_context "$context_length")"
  set_env_if_needed CLAUDE_CODE_AUTO_COMPACT_WINDOW "$context_length" 0
  set_env_if_needed CLAUDE_CODE_MAX_OUTPUT_TOKENS "$max_output_tokens" 0

  if (( context_length <= 15000 )); then
    set_env_if_needed DISABLE_AUTO_COMPACT "${CLAUDE_DEV_DISABLE_AUTO_COMPACT_FOR_SMALL_CONTEXT:-1}" 0
  fi
}

set_ollama_context_env() {
  local model="$1"
  local context_length

  if ! context_length="$(get_ollama_model_context_length "$model")"; then
    return 0
  fi

  apply_context_limits "$context_length"
}

set_lmstudio_context_env() {
  local model="$1"
  local instance_id="${2:-}"
  local context_length

  if ! context_length="$(get_lmstudio_model_context_length "$model" "$instance_id")"; then
    return 0
  fi

  apply_context_limits "$context_length"
}

