prompt_for_selection() {
  local title="$1"
  local default_index="${2:-0}"
  shift 2
  local -a options=("$@")
  local selected="$default_index"
  local key
  local idx

  if [[ "${#options[@]}" -eq 0 ]]; then
    return 1
  fi

  tput civis >/dev/stderr 2>/dev/null || true
  while true; do
    printf '\033[2J\033[H' >&2
    printf '%s\n\n' "$title" >&2
    for idx in "${!options[@]}"; do
      if [[ "$idx" -eq "$selected" ]]; then
        printf '  \033[1;7m> %s\033[0m\n' "${options[$idx]}" >&2
      else
        printf '    %s\n' "${options[$idx]}" >&2
      fi
    done

    IFS= read -rsn1 key || true
    if [[ "$key" == $'\x1b' ]]; then
      IFS= read -rsn2 key || true
      case "$key" in
        '[A')
          selected=$(( (selected - 1 + ${#options[@]}) % ${#options[@]} ))
          ;;
        '[B')
          selected=$(( (selected + 1) % ${#options[@]} ))
          ;;
      esac
    elif [[ -z "$key" || "$key" == $'\n' || "$key" == $'\r' ]]; then
      break
    fi
  done

  printf '\033[2J\033[H' >&2
  tput cnorm >/dev/stderr 2>/dev/null || true
  printf '%s' "$selected"
}

should_use_model_picker() {
  if [[ "${CLAUDE_DEV_SKIP_MODEL_PICKER:-0}" == "1" ]]; then
    return 1
  fi
  if [[ "${CLAUDE_DEV_MODEL_PICKER:-1}" == "0" ]]; then
    return 1
  fi
  if [[ $# -ne 0 ]]; then
    return 1
  fi
  if [[ ! -t 0 || ! -t 1 ]]; then
    return 1
  fi
  return 0
}

choose_provider() {
  local preferred="$1"
  local picker_enabled="$2"
  local -a providers=()
  local -a labels=()
  local default_index=0
  local selected_index=0

  if [[ "${#OLLAMA_MODELS[@]}" -gt 0 ]]; then
    providers+=("ollama")
    labels+=("Ollama (${#OLLAMA_MODELS[@]} local model(s))")
  fi
  if [[ "${#LMSTUDIO_MODELS[@]}" -gt 0 ]]; then
    providers+=("lmstudio")
    labels+=("LM Studio (${#LMSTUDIO_MODELS[@]} local model(s))")
  fi

  if [[ "${#providers[@]}" -eq 0 ]]; then
    printf 'No local model provider is available. Start Ollama or LM Studio and try again.\n' >&2
    exit 1
  fi

  if [[ "${#providers[@]}" -eq 1 ]]; then
    printf '%s' "${providers[0]}"
    return 0
  fi

  if [[ -n "$preferred" ]]; then
    for selected_index in "${!providers[@]}"; do
      if [[ "${providers[$selected_index]}" == "$preferred" ]]; then
        default_index="$selected_index"
        break
      fi
    done
  fi

  if [[ "$picker_enabled" == "1" ]]; then
    selected_index="$(prompt_for_selection 'Select a local runtime for tiny-crab (arrow keys + Enter):' "$default_index" "${labels[@]}")"
    printf '%s' "${providers[$selected_index]}"
    return 0
  fi

  printf '%s' "${providers[$default_index]}"
}

pick_ollama_model() {
  local default_model="$1"
  local picker_enabled="$2"
  local idx
  local default_index=0

  if [[ "${#OLLAMA_MODELS[@]}" -eq 0 ]]; then
    printf 'No Ollama models found. Install one first with `ollama pull <model>`.\n' >&2
    exit 1
  fi

  if [[ -n "$default_model" ]]; then
    for idx in "${!OLLAMA_MODELS[@]}"; do
      if [[ "${OLLAMA_MODELS[$idx]}" == "$default_model" ]]; then
        default_index="$idx"
        break
      fi
    done
  fi

  if [[ "$picker_enabled" == "1" ]]; then
    idx="$(prompt_for_selection 'Select an Ollama model for tiny-crab (arrow keys + Enter):' "$default_index" "${OLLAMA_MODELS[@]}")"
    printf '%s' "${OLLAMA_MODELS[$idx]}"
    return 0
  fi

  if [[ -n "$default_model" ]]; then
    printf '%s' "$default_model"
  else
    printf '%s' "${OLLAMA_MODELS[$default_index]}"
  fi
}

pick_lmstudio_model() {
  local default_model="$1"
  local picker_enabled="$2"
  local -a labels=()
  local idx
  local default_index=0
  local selected_index=0

  if [[ "${#LMSTUDIO_MODELS[@]}" -eq 0 ]]; then
    printf 'No LM Studio models were found. Download or index at least one local model first.\n' >&2
    exit 1
  fi

  for idx in "${!LMSTUDIO_MODELS[@]}"; do
    IFS=$'\t' read -r key display max_ctx loaded_id <<<"${LMSTUDIO_MODELS[$idx]}"
    labels+=("$display [$key]")
    if [[ -n "$default_model" && "$key" == "$default_model" ]]; then
      default_index="$idx"
    fi
  done

  if [[ "$picker_enabled" == "1" ]]; then
    selected_index="$(prompt_for_selection 'Select an LM Studio model for tiny-crab (arrow keys + Enter):' "$default_index" "${labels[@]}")"
    IFS=$'\t' read -r key _display _max_ctx _loaded_id <<<"${LMSTUDIO_MODELS[$selected_index]}"
    printf '%s' "$key"
    return 0
  fi

  if [[ -n "$default_model" ]]; then
    printf '%s' "$default_model"
  else
    IFS=$'\t' read -r key _display _max_ctx _loaded_id <<<"${LMSTUDIO_MODELS[$default_index]}"
    printf '%s' "$key"
  fi
}

find_lmstudio_loaded_instance() {
  local model="$1"
  local row
  local key
  local display
  local max_ctx
  local loaded_id

  for row in "${LMSTUDIO_MODELS[@]}"; do
    IFS=$'\t' read -r key display max_ctx loaded_id <<<"$row"
    if [[ "$key" == "$model" ]]; then
      if [[ -n "$loaded_id" ]]; then
        printf '%s' "$loaded_id"
      fi
      return 0
    fi
  done

  return 1
}

warmup_ollama_model_with_progress() {
  local model="$1"
  local timeout_sec="${CLAUDE_DEV_MODEL_LOAD_TIMEOUT_SEC:-180}"
  local generate_url="${OLLAMA_BASE_URL%/}/api/generate"
  local payload
  local tmp_out
  local tmp_err
  local pid

  payload=$(printf '{"model":"%s","prompt":"ping","stream":false,"keep_alive":"15m","options":{"num_predict":1}}' "$model")
  tmp_out="$(mktemp "${TMPDIR:-/tmp}/tiny-crab-ollama-warmup-out.XXXXXX")"
  tmp_err="$(mktemp "${TMPDIR:-/tmp}/tiny-crab-ollama-warmup-err.XXXXXX")"

  if command -v curl >/dev/null 2>&1; then
    curl -sS --max-time "$timeout_sec" \
      -H 'Content-Type: application/json' \
      -X POST "$generate_url" \
      -d "$payload" >"$tmp_out" 2>"$tmp_err" &
  else
    ollama run "$model" 'ping' >"$tmp_out" 2>"$tmp_err" &
  fi
  pid=$!

  printf "Loading '%s' into memory " "$model" >&2
  while kill -0 "$pid" 2>/dev/null; do
    printf '#' >&2
    sleep 0.1
  done

  if wait "$pid"; then
    printf ' done\n' >&2
  else
    printf ' failed\n' >&2
    if [[ -s "$tmp_err" ]]; then
      printf 'Model warmup warning: %s\n' "$(head -n 1 "$tmp_err")" >&2
    fi
  fi

  rm -f "$tmp_out" "$tmp_err"
}

load_lmstudio_model_with_progress() {
  local model="$1"
  local requested_context="${2:-}"
  local timeout_sec="${CLAUDE_DEV_MODEL_LOAD_TIMEOUT_SEC:-180}"
  local payload
  local tmp_out
  local tmp_err
  local pid
  local instance_id

  if instance_id="$(find_lmstudio_loaded_instance "$model")" && [[ -n "$instance_id" ]]; then
    ACTIVE_INSTANCE_ID="$instance_id"
    return 0
  fi

  if [[ -n "$requested_context" ]]; then
    payload=$(printf '{"model":"%s","context_length":%s,"echo_load_config":true}' "$model" "$requested_context")
  else
    payload=$(printf '{"model":"%s","echo_load_config":true}' "$model")
  fi

  tmp_out="$(mktemp "${TMPDIR:-/tmp}/tiny-crab-lmstudio-load-out.XXXXXX")"
  tmp_err="$(mktemp "${TMPDIR:-/tmp}/tiny-crab-lmstudio-load-err.XXXXXX")"

  curl_json POST "${LMSTUDIO_BASE_URL%/}/api/v1/models/load" "$payload" >"$tmp_out" 2>"$tmp_err" &
  pid=$!

  printf "Loading '%s' into memory " "$model" >&2
  while kill -0 "$pid" 2>/dev/null; do
    printf '#' >&2
    sleep 0.1
  done

  if wait "$pid"; then
    printf ' done\n' >&2
    instance_id="$(json_node 'const fs=require("fs"); const raw=fs.readFileSync(0,"utf8"); const payload=raw ? JSON.parse(raw) : {}; if (typeof payload?.instance_id === "string" && payload.instance_id) console.log(payload.instance_id);' <"$tmp_out")"
    ACTIVE_INSTANCE_ID="${instance_id:-$model}"
  else
    printf ' failed\n' >&2
    if [[ -s "$tmp_err" ]]; then
      printf 'LM Studio load failed: %s\n' "$(head -n 1 "$tmp_err")" >&2
    fi
    rm -f "$tmp_out" "$tmp_err"
    exit 1
  fi

  rm -f "$tmp_out" "$tmp_err"
}

unload_ollama_model_from_memory() {
  local model="$1"
  local generate_url="${OLLAMA_BASE_URL%/}/api/generate"
  local payload

  if [[ -z "$model" ]]; then
    return 1
  fi

  payload=$(printf '{"model":"%s","keep_alive":0}' "$model")

  if command -v curl >/dev/null 2>&1; then
    if curl -sS --max-time 20 \
      -H 'Content-Type: application/json' \
      -X POST "$generate_url" \
      -d "$payload" >/dev/null 2>&1; then
      return 0
    fi
  fi

  if has_ollama; then
    ollama stop "$model" >/dev/null 2>&1 && return 0
  fi

  return 1
}

unload_lmstudio_model_from_memory() {
  local instance_id="$1"

  if [[ -z "$instance_id" ]]; then
    return 1
  fi

  curl_json POST "${LMSTUDIO_BASE_URL%/}/api/v1/models/unload" \
    "$(printf '{"instance_id":"%s"}' "$instance_id")" >/dev/null 2>&1
}

get_running_ollama_models() {
  if has_ollama; then
    ollama ps 2>/dev/null | awk 'NR > 1 && NF > 0 { print $1 }'
  fi
}

unload_models_on_exit() {
  local enabled="${CLAUDE_DEV_UNLOAD_ON_EXIT:-1}"
  local model
  local seen
  local existing
  local -a models=()
  local -a unique_models=()

  if [[ "$enabled" != "1" ]]; then
    return 0
  fi

  case "${ACTIVE_PROVIDER:-}" in
    lmstudio)
      unload_lmstudio_model_from_memory "${ACTIVE_INSTANCE_ID:-${ACTIVE_MODEL:-}}" || true
      return 0
      ;;
    ollama)
      ;;
    *)
      return 0
      ;;
  esac

  if has_ollama; then
    while IFS= read -r model; do
      if [[ -n "$model" ]]; then
        models+=("$model")
      fi
    done < <(get_running_ollama_models)
  fi

  if [[ -n "${ACTIVE_MODEL:-}" ]]; then
    models+=("$ACTIVE_MODEL")
  fi

  for model in "${models[@]-}"; do
    seen=0
    for existing in "${unique_models[@]-}"; do
      if [[ "$existing" == "$model" ]]; then
        seen=1
        break
      fi
    done
    if [[ "$seen" -eq 0 ]]; then
      unique_models+=("$model")
    fi
  done

  for model in "${unique_models[@]-}"; do
    unload_ollama_model_from_memory "$model" || true
  done
}

resolve_bun_runner() {
  if command -v bun >/dev/null 2>&1; then
    printf 'bun'
    return 0
  fi

  if command -v npx >/dev/null 2>&1; then
    printf '%s' "$(command -v npx)"
    return 0
  fi

  for npx_path in /opt/homebrew/bin/npx /usr/local/bin/npx; do
    if [[ -x "$npx_path" ]]; then
      printf '%s' "$npx_path"
      return 0
    fi
  done

  if command -v npm >/dev/null 2>&1; then
    npm_bin="$(npm bin -g 2>/dev/null || true)"
    if [[ -n "$npm_bin" && -x "$npm_bin/npx" ]]; then
      printf '%s' "$npm_bin/npx"
      return 0
    fi
  fi

  return 1
}

on_exit() {
  unload_models_on_exit
  cleanup_tui
}

trap on_exit EXIT

OLLAMA_BASE_URL="$(normalize_url "${CLAUDE_DEV_OLLAMA_BASE_URL:-${OLLAMA_HOST:-127.0.0.1:11434}}")"
LMSTUDIO_BASE_URL="$(normalize_url "${CLAUDE_DEV_LMSTUDIO_BASE_URL:-${LMSTUDIO_BASE_URL:-127.0.0.1:1234}}")"
PREFERRED_PROVIDER="${CLAUDE_CODE_LOCAL_MODEL_PROVIDER:-${CLAUDE_DEV_LOCAL_PROVIDER:-}}"
DEFAULT_MODEL="${CLAUDE_DEV_DEFAULT_MODEL:-}"
OLLAMA_DEFAULT_MODEL="${CLAUDE_DEV_OLLAMA_MODEL:-${CLAUDE_OLLAMA_MODEL:-${OLLAMA_MODEL:-${DEFAULT_MODEL:-llama3.1:8b}}}}"
LMSTUDIO_DEFAULT_MODEL="${CLAUDE_DEV_LMSTUDIO_MODEL:-${LMSTUDIO_MODEL:-${DEFAULT_MODEL:-}}}"
ACTIVE_PROVIDER=""
ACTIVE_MODEL=""
ACTIVE_INSTANCE_ID=""
LOCAL_PROVIDER_AUTH_TOKEN=""

set_common_local_mode_env

OLLAMA_MODELS=()
while IFS= read -r line; do
  if [[ -n "$line" ]]; then
    OLLAMA_MODELS+=("$line")
  fi
done < <(get_ollama_models 2>/dev/null || true)

LMSTUDIO_MODELS=()
while IFS= read -r line; do
  if [[ -n "$line" ]]; then
    LMSTUDIO_MODELS+=("$line")
  fi
done < <(get_lmstudio_models 2>/dev/null || true)

picker_enabled=0
if should_use_model_picker "$@"; then
  picker_enabled=1
fi

selected_provider="$(choose_provider "$PREFERRED_PROVIDER" "$picker_enabled")"

case "$selected_provider" in
  ollama)
    selected_model="$(pick_ollama_model "$OLLAMA_DEFAULT_MODEL" "$picker_enabled")"
    set_ollama_model_env "$selected_model" 1
    if [[ "$picker_enabled" == "1" ]]; then
      warmup_ollama_model_with_progress "$selected_model"
    fi
    set_ollama_context_env "$selected_model"
    ;;
  lmstudio)
    if [[ -z "$LMSTUDIO_DEFAULT_MODEL" && "${#LMSTUDIO_MODELS[@]}" -gt 0 ]]; then
      IFS=$'\t' read -r LMSTUDIO_DEFAULT_MODEL _display _max_ctx _loaded_id <<<"${LMSTUDIO_MODELS[0]}"
    fi
    selected_model="$(pick_lmstudio_model "$LMSTUDIO_DEFAULT_MODEL" "$picker_enabled")"
    set_lmstudio_model_env "$selected_model" 1

    requested_context=""
    if [[ -n "${CLAUDE_DEV_CONTEXT_WINDOW_CAP:-}" && "${CLAUDE_DEV_CONTEXT_WINDOW_CAP:-}" =~ ^[0-9]+$ ]]; then
      requested_context="${CLAUDE_DEV_CONTEXT_WINDOW_CAP}"
    fi

    if [[ "$picker_enabled" == "1" || -z "${ACTIVE_INSTANCE_ID:-}" ]]; then
      load_lmstudio_model_with_progress "$selected_model" "$requested_context"
    else
      if instance_id="$(find_lmstudio_loaded_instance "$selected_model")" && [[ -n "$instance_id" ]]; then
        ACTIVE_INSTANCE_ID="$instance_id"
      fi
    fi
    set_lmstudio_context_env "$selected_model" "${ACTIVE_INSTANCE_ID:-}"
    ;;
  *)
    printf 'Unsupported local provider: %s\n' "$selected_provider" >&2
    exit 1
    ;;
esac

runner="$(resolve_bun_runner)" || {
  printf 'Tiny Crab requires Bun. Install Bun (https://bun.sh) or ensure `npx` is available.\n' >&2
  exit 1
}

if [[ "$runner" == "bun" ]]; then
  runtime_cmd=(bun "$REPO_DIR/src/entrypoints/cli-dev-bootstrap.ts")
else
  runtime_cmd=("$runner" --yes bun "$REPO_DIR/src/entrypoints/cli-dev-bootstrap.ts")
fi

if "${runtime_cmd[@]}" "$@"; then
  exit_code=0
else
  exit_code=$?
fi

exit "$exit_code"
