#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  if [[ "$LINK_TARGET" = /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/$LINK_TARGET"
  fi
done
REPO_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# Some environments launch with a reduced PATH that omits Homebrew bins.
for bin_dir in /opt/homebrew/bin /usr/local/bin; do
  case ":$PATH:" in
    *":$bin_dir:"*) ;;
    *) PATH="$bin_dir:$PATH" ;;
  esac
done
export PATH

# Keep this local build fully separate from the official install.
export CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.tiny-crab}"

normalize_url() {
  local raw="$1"
  if [[ "$raw" == http://* || "$raw" == https://* ]]; then
    printf '%s' "$raw"
  else
    printf 'http://%s' "$raw"
  fi
}

cleanup_tui() {
  tput cnorm >/dev/stderr 2>/dev/null || true
}

has_ollama() {
  command -v ollama >/dev/null 2>&1
}

get_ollama_models() {
  ollama list 2>/dev/null | awk 'NR > 1 && NF > 0 { print $1 }'
}

set_env_if_needed() {
  local name="$1"
  local value="$2"
  local force="${3:-0}"
  if [[ "$force" == "1" || -z "${!name:-}" ]]; then
    export "$name=$value"
  fi
}

set_ollama_model_env() {
  local model="$1"
  local force="${2:-0}"
  set_env_if_needed ANTHROPIC_BASE_URL "$OLLAMA_BASE_URL" "$force"
  set_env_if_needed ANTHROPIC_API_KEY "${CLAUDE_DEV_OLLAMA_API_KEY:-ollama}" "$force"
  set_env_if_needed ANTHROPIC_AUTH_TOKEN "${CLAUDE_DEV_OLLAMA_AUTH_TOKEN:-ollama}" "$force"
  set_env_if_needed ANTHROPIC_MODEL "$model" "$force"
  set_env_if_needed ANTHROPIC_SMALL_FAST_MODEL "$model" "$force"
  set_env_if_needed ANTHROPIC_DEFAULT_SONNET_MODEL "$model" "$force"
  set_env_if_needed ANTHROPIC_DEFAULT_HAIKU_MODEL "$model" "$force"
  set_env_if_needed ANTHROPIC_DEFAULT_OPUS_MODEL "$model" "$force"
  set_env_if_needed ANTHROPIC_CUSTOM_MODEL_OPTION "$model" "$force"
  set_env_if_needed ANTHROPIC_CUSTOM_MODEL_OPTION_NAME "$model" "$force"
  set_env_if_needed ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION "Local Ollama model" "$force"
}

get_ollama_model_context_length() {
  local model="$1"
  local context_length
  context_length="$(
    ollama show "$model" 2>/dev/null \
      | awk 'tolower($0) ~ /context length/ { print $0; exit }' \
      | tr -cd '0-9'
  )"
  if [[ -z "$context_length" || "$context_length" -le 0 ]]; then
    return 1
  fi
  printf '%s' "$context_length"
}

derive_max_output_tokens_for_context() {
  local context_length="$1"
  local max_output_tokens=$(( context_length / 16 ))
  local max_output_cap="${CLAUDE_DEV_MAX_OUTPUT_TOKENS_CAP:-2048}"

  if [[ ! "$max_output_cap" =~ ^[0-9]+$ ]] || (( max_output_cap <= 0 )); then
    max_output_cap=2048
  fi

  # Keep local inference responsive while leaving enough headroom for context.
  if (( max_output_tokens < 512 )); then
    max_output_tokens=512
  fi
  if (( max_output_tokens > max_output_cap )); then
    max_output_tokens=$max_output_cap
  fi
  if (( max_output_tokens >= context_length )); then
    max_output_tokens=$(( context_length - 1 ))
  fi
  if (( max_output_tokens < 256 )); then
    max_output_tokens=256
  fi

  printf '%s' "$max_output_tokens"
}

set_ollama_context_env() {
  local model="$1"
  local context_length
  local context_cap
  local max_output_tokens

  if ! context_length="$(get_ollama_model_context_length "$model")"; then
    return 0
  fi

  context_cap="${CLAUDE_DEV_CONTEXT_WINDOW_CAP:-32768}"
  if [[ "$context_cap" =~ ^[0-9]+$ ]] && (( context_cap > 0 )) && (( context_length > context_cap )); then
    context_length="$context_cap"
  fi

  max_output_tokens="$(derive_max_output_tokens_for_context "$context_length")"
  set_env_if_needed CLAUDE_CODE_AUTO_COMPACT_WINDOW "$context_length" 0
  set_env_if_needed CLAUDE_CODE_MAX_OUTPUT_TOKENS "$max_output_tokens" 0

  # Very small contexts can trigger immediate auto-compact loops; keep manual
  # /compact available instead.
  if (( context_length <= 15000 )); then
    set_env_if_needed DISABLE_AUTO_COMPACT "${CLAUDE_DEV_DISABLE_AUTO_COMPACT_FOR_SMALL_CONTEXT:-1}" 0
  fi
}

should_use_model_picker() {
  if [[ "${CLAUDE_DEV_SKIP_MODEL_PICKER:-0}" == "1" ]]; then
    return 1
  fi
  if [[ "${CLAUDE_DEV_MODEL_PICKER:-1}" == "0" ]]; then
    return 1
  fi
  if [[ $# -ne 0 ]]; then
    return 1
  fi
  if [[ ! -t 0 || ! -t 1 ]]; then
    return 1
  fi
  return 0
}

resolve_bun_runner() {
  if command -v bun >/dev/null 2>&1; then
    printf 'bun'
    return 0
  fi

  if command -v npx >/dev/null 2>&1; then
    printf '%s' "$(command -v npx)"
    return 0
  fi

  # Some constrained shells have a stripped PATH that omits Homebrew bins.
  for npx_path in /opt/homebrew/bin/npx /usr/local/bin/npx; do
    if [[ -x "$npx_path" ]]; then
      printf '%s' "$npx_path"
      return 0
    fi
  done

  if command -v npm >/dev/null 2>&1; then
    npm_bin="$(npm bin -g 2>/dev/null || true)"
    if [[ -n "$npm_bin" && -x "$npm_bin/npx" ]]; then
      printf '%s' "$npm_bin/npx"
      return 0
    fi
  fi

  if [[ -x /opt/homebrew/bin/npm ]]; then
    npm_bin="$(/opt/homebrew/bin/npm bin -g 2>/dev/null || true)"
    if [[ -n "$npm_bin" && -x "$npm_bin/npx" ]]; then
      printf '%s' "$npm_bin/npx"
      return 0
    fi
  fi

  if [[ -x /usr/local/bin/npm ]]; then
    npm_bin="$(/usr/local/bin/npm bin -g 2>/dev/null || true)"
    if [[ -n "$npm_bin" && -x "$npm_bin/npx" ]]; then
      printf '%s' "$npm_bin/npx"
      return 0
    fi
  fi

  if [[ -x /opt/homebrew/bin/node ]]; then
    node_bin="$(/opt/homebrew/bin/node -p 'process.execPath' 2>/dev/null || true)"
    if [[ -n "$node_bin" ]]; then
      guess_npx="${node_bin%/node}/npx"
      if [[ -x "$guess_npx" ]]; then
        printf '%s' "$guess_npx"
        return 0
      fi
    fi
  fi

  if [[ -x /usr/local/bin/node ]]; then
    node_bin="$(/usr/local/bin/node -p 'process.execPath' 2>/dev/null || true)"
    if [[ -n "$node_bin" ]]; then
      guess_npx="${node_bin%/node}/npx"
      if [[ -x "$guess_npx" ]]; then
        printf '%s' "$guess_npx"
        return 0
      fi
    fi
  fi

  if [[ -x /opt/homebrew/bin/npx ]]; then
    printf '%s' '/opt/homebrew/bin/npx'
    return 0
  fi

  if [[ -x /usr/local/bin/npx ]]; then
    printf '%s' '/usr/local/bin/npx'
    return 0
  fi

  return 1
}

prompt_for_model() {
  local default_model="$1"
  local -a models=()
  local line
  local idx
  local selected=0
  local key

  while IFS= read -r line; do
    if [[ -n "$line" ]]; then
      models+=("$line")
    fi
  done < <(get_ollama_models)

  if [[ "${#models[@]}" -eq 0 ]]; then
    printf 'No Ollama models found. Install one first with `ollama pull <model>`.\n' >&2
    exit 1
  fi

  for idx in "${!models[@]}"; do
    if [[ "${models[$idx]}" == "$default_model" ]]; then
      selected="$idx"
      break
    fi
  done

  tput civis >/dev/stderr 2>/dev/null || true
  while true; do
    printf '\033[2J\033[H' >&2
    printf 'Select an Ollama model for tiny-crab (arrow keys + Enter):\n\n' >&2
    for idx in "${!models[@]}"; do
      if [[ "$idx" -eq "$selected" ]]; then
        printf '  \033[1;7m> %s\033[0m\n' "${models[$idx]}" >&2
      else
        printf '    %s\n' "${models[$idx]}" >&2
      fi
    done

    IFS= read -rsn1 key || true
    if [[ "$key" == $'\x1b' ]]; then
      IFS= read -rsn2 key || true
      case "$key" in
        '[A')
          selected=$(( (selected - 1 + ${#models[@]}) % ${#models[@]} ))
          ;;
        '[B')
          selected=$(( (selected + 1) % ${#models[@]} ))
          ;;
      esac
    elif [[ -z "$key" || "$key" == $'\n' || "$key" == $'\r' ]]; then
      break
    fi
  done

  printf '\033[2J\033[H' >&2
  tput cnorm >/dev/stderr 2>/dev/null || true
  printf '%s' "${models[$selected]}"
}

warmup_model_with_progress() {
  local model="$1"
  local timeout_sec="${CLAUDE_DEV_MODEL_LOAD_TIMEOUT_SEC:-180}"
  local generate_url="${OLLAMA_BASE_URL%/}/api/generate"
  local payload
  local tmp_out
  local tmp_err
  local pid

  payload=$(printf '{"model":"%s","prompt":"ping","stream":false,"keep_alive":"15m","options":{"num_predict":1}}' "$model")
  tmp_out="$(mktemp "${TMPDIR:-/tmp}/tiny-crab-warmup-out.XXXXXX")"
  tmp_err="$(mktemp "${TMPDIR:-/tmp}/tiny-crab-warmup-err.XXXXXX")"

  if command -v curl >/dev/null 2>&1; then
    curl -sS --max-time "$timeout_sec" \
      -H 'Content-Type: application/json' \
      -X POST "$generate_url" \
      -d "$payload" >"$tmp_out" 2>"$tmp_err" &
  else
    ollama run "$model" "ping" >"$tmp_out" 2>"$tmp_err" &
  fi
  pid=$!

  printf "Loading '%s' into memory " "$model"
  while kill -0 "$pid" 2>/dev/null; do
    printf '#'
    sleep 0.1
  done

  if wait "$pid"; then
    printf ' done\n'
  else
    printf ' failed\n'
    if [[ -s "$tmp_err" ]]; then
      printf 'Model warmup warning: %s\n' "$(head -n 1 "$tmp_err")" >&2
    fi
  fi

  rm -f "$tmp_out" "$tmp_err"
}

unload_ollama_model_from_memory() {
  local model="$1"
  local generate_url="${OLLAMA_BASE_URL%/}/api/generate"
  local payload

  if [[ -z "$model" ]]; then
    return 1
  fi

  payload=$(printf '{"model":"%s","keep_alive":0}' "$model")

  if command -v curl >/dev/null 2>&1; then
    if curl -sS --max-time 20 \
      -H 'Content-Type: application/json' \
      -X POST "$generate_url" \
      -d "$payload" >/dev/null 2>&1; then
      return 0
    fi
  fi

  if has_ollama; then
    ollama stop "$model" >/dev/null 2>&1 && return 0
  fi

  return 1
}

get_running_ollama_models() {
  ollama ps 2>/dev/null | awk 'NR > 1 && NF > 0 { print $1 }'
}

unload_models_on_exit() {
  local enabled="${CLAUDE_DEV_UNLOAD_ON_EXIT:-1}"
  local model
  local seen
  local existing
  local -a models=()
  local -a unique_models=()

  if [[ "$enabled" != "1" ]]; then
    return 0
  fi
  if ! has_ollama; then
    return 0
  fi

  while IFS= read -r model; do
    if [[ -n "$model" ]]; then
      models+=("$model")
    fi
  done < <(get_running_ollama_models)

  if [[ -n "${ACTIVE_MODEL:-}" ]]; then
    models+=("$ACTIVE_MODEL")
  fi

  for model in "${models[@]-}"; do
    seen=0
    for existing in "${unique_models[@]-}"; do
      if [[ "$existing" == "$model" ]]; then
        seen=1
        break
      fi
    done
    if [[ "$seen" -eq 0 ]]; then
      unique_models+=("$model")
    fi
  done

  for model in "${unique_models[@]-}"; do
    unload_ollama_model_from_memory "$model" || true
  done
}

on_exit() {
  unload_models_on_exit
  cleanup_tui
}

trap on_exit EXIT

OLLAMA_BASE_URL="$(normalize_url "${CLAUDE_DEV_OLLAMA_BASE_URL:-${OLLAMA_HOST:-127.0.0.1:11434}}")"
DEFAULT_MODEL="${CLAUDE_DEV_DEFAULT_MODEL:-${CLAUDE_OLLAMA_MODEL:-${OLLAMA_MODEL:-llama3.1:8b}}}"
ACTIVE_MODEL="$DEFAULT_MODEL"

# Mark this launcher as local-model-only mode for onboarding and setup flows.
set_env_if_needed CLAUDE_CODE_LOCAL_MODEL_MODE "${CLAUDE_CODE_LOCAL_MODEL_MODE:-1}" 0

# Guard local-model sessions against runaway tool loops on weaker models.
# Users can override with CLAUDE_DEV_MAX_TURNS or CLAUDE_CODE_MAX_TURNS.
set_env_if_needed CLAUDE_CODE_MAX_TURNS "${CLAUDE_DEV_MAX_TURNS:-8}" 0

# Local models are slower with high effort defaults; keep a responsive default.
set_env_if_needed CLAUDE_CODE_EFFORT_LEVEL "${CLAUDE_DEV_EFFORT_LEVEL:-low}" 0

# Local Ollama mode should not call nonessential Anthropic endpoints.
set_env_if_needed CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC "${CLAUDE_DEV_DISABLE_NONESSENTIAL_TRAFFIC:-1}" 0

# Disable Claude thinking modes by default for local Ollama models.
# Many local models (including Gemma) emit hidden thinking tokens without
# assistant text, which makes turns appear to hang or return empty output.
set_env_if_needed CLAUDE_CODE_DISABLE_THINKING "${CLAUDE_DEV_DISABLE_THINKING:-1}" 0
set_env_if_needed DISABLE_INTERLEAVED_THINKING "${CLAUDE_DEV_DISABLE_INTERLEAVED_THINKING:-1}" 0

# Hard-disable cloud/provider auth paths in local mode.
unset CLAUDE_CODE_USE_BEDROCK CLAUDE_CODE_USE_VERTEX CLAUDE_CODE_USE_FOUNDRY
unset USE_STAGING_OAUTH USE_LOCAL_OAUTH
unset CLAUDE_CODE_OAUTH_TOKEN CLAUDE_CODE_OAUTH_TOKEN_FILE_DESCRIPTOR

# Force this launcher to use Ollama wiring.
set_ollama_model_env "$DEFAULT_MODEL" 1
ACTIVE_MODEL="$DEFAULT_MODEL"

if should_use_model_picker "$@"; then
  if ! has_ollama; then
    printf 'Ollama is not installed or not on PATH. Install/start Ollama, then run tiny-crab again.\n' >&2
    exit 1
  fi
  if ! ollama list >/dev/null 2>&1; then
    printf 'Unable to query Ollama models. Start Ollama first (for example: `ollama serve`).\n' >&2
    exit 1
  fi

  selected_model="$(prompt_for_model "$DEFAULT_MODEL")"
  ACTIVE_MODEL="$selected_model"
  set_ollama_model_env "$selected_model" 1
  warmup_model_with_progress "$selected_model"
fi

set_ollama_context_env "$ACTIVE_MODEL"

runner="$(resolve_bun_runner)" || {
  printf 'Tiny Crab requires Bun. Install Bun (https://bun.sh) or ensure `npx` is available.\n' >&2
  exit 1
}

if [[ "$runner" == "bun" ]]; then
  runtime_cmd=(bun "$REPO_DIR/src/entrypoints/cli-dev-bootstrap.ts")
else
  runtime_cmd=("$runner" --yes bun "$REPO_DIR/src/entrypoints/cli-dev-bootstrap.ts")
fi

if "${runtime_cmd[@]}" "$@"; then
  exit_code=0
else
  exit_code=$?
fi

exit "$exit_code"
